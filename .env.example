# App
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=debug

# Externally-reachable origin for hosted-checkout URLs (used when LAZY_CHECKOUT=true).
PUBLIC_BASE_URL=http://localhost:8080
# When true, POST /api/payments returns ${PUBLIC_BASE_URL}/pay/<order_id>?t=<token>
# and defers the Stripe Session creation until the user opens that URL.
LAZY_CHECKOUT=false
# 32+ bytes random string. Signs hosted-checkout URLs to prevent enumeration.
# When empty, /pay/:id accepts any order_id (dev-only).
CHECKOUT_TOKEN_SECRET=
# How long a hosted-checkout URL is valid (seconds, default 24h).
CHECKOUT_TOKEN_TTL_SECONDS=86400
# Stripe SDK call rate cap, fleet-wide via Redis token bucket. Keep below
# your Stripe quota with safety margin.
STRIPE_RATE_LIMIT=80
# Required. HMAC-SHA256 key that turns (merchant_id, merchant_order_id) into
# the 16-byte transaction_id and 12-byte order_id (with shard byte at
# order_id[0]). 32+ bytes random; never rotate without a backfill — every
# existing row's identity depends on it.
TRANSACTION_ID_SECRET=replace-me-with-32-byte-random-transaction-secret

# MySQL — primary pool (merchants, pending_txs, block_cursors).
DB_DSN=root:root@tcp(localhost:3306)/payments?parseTime=true&loc=UTC
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=25
# Optional. Sharded pools for the orders_<shard> family.
#   - empty / unset    : all 16 shard tables collocate on DB_DSN (dev / small).
#   - exactly 16 DSNs  : one MySQL primary per shard (production scale-out).
# Comma-separated. Order corresponds to shard index 0..15.
ORDERS_SHARD_DSNS=

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka — only `payment.confirmed` is published from this app.
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_CONFIRMED=payment.confirmed
KAFKA_TOPIC_DLQ=payment.confirmed.dlq
KAFKA_CONSUMER_GROUP=payment-engine

# Stripe
# STRIPE_MODE=live  -> hits api.stripe.com (default; requires real keys)
# STRIPE_MODE=fake  -> in-process synthetic responses, no network, no rate limits
STRIPE_MODE=live
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_API_VERSION=2024-06-20
STRIPE_DEFAULT_CURRENCY=USD

# Blockchain
ETH_RPC_WS=wss://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ETH_RPC_HTTP=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ETH_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
ETH_CHAIN_ID=11155111
ETH_REQUIRED_CONFIRMATIONS=12
ETH_START_BLOCK=0

# Security
HMAC_SECRET=replace-me-with-32-byte-random-secret
HMAC_TIMESTAMP_SKEW_SECONDS=300
